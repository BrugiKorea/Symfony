<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Pogodynka{% endblock %}</title>

    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    {% endblock %}
</head>

<body>
<div class="container mt-4">
    <header class="mb-4">
        <h1 class="mb-3">🌤️ Pogodynka</h1>
        <nav>
            <a href="http://pogodynka.localhost:53965/location" class="btn btn-outline-primary me-2">Lokalizacje</a>
            <a href="http://pogodynka.localhost:53965/measurement" class="btn btn-outline-success">Prognozy</a>
        </nav>
    </header>


    {% block body %}{% endblock %}
</div>

<style>
    body {
        background: url("https://placehold.co/100x100/FFFFFF/EFEFEF/png?text=53965");
    }
</style>

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}

{% if is_granted('ROLE_USER') %}
    <a href="{{ path('app_logout') }}">Logout</a>
{% else %}
    <a href="{{ path('app_login') }}">Login</a>
{% endif %}
</body>
</html>
